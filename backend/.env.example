NODE_ENV=development
NETWORK=devnet

# Solana
RPC_ENDPOINT=https://api.devnet.solana.com
PROGRAM_ID=FqtrHgdYTph1DSP9jDYD7xrKPrjSjCTtnw6fyKMmboYk
# Base58-encoded 64-byte secret key of the server wallet that subsidizes gas fees.
# Generate with: solana-keygen new --no-bip39-passphrase --outfile fee-payer.json
# then: cat fee-payer.json | python3 -c "import sys,json,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
# NEVER commit the real value — use a secrets manager (e.g. Google Secret Manager) in production.
FEE_PAYER_PRIVATE_KEY=replace_me_with_base58_secret_key

# AI (Groq)
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_ACK_MS=200
GROQ_TIMEOUT_BG_MS=2000

# Audio (Deepgram)
DEEPGRAM_API_KEY=replace_me
DEEPGRAM_TTS_MODEL=aura-2-orion-en
DEEPGRAM_STT_MODEL=nova-2

# IoT
MQTT_BROKER_URL=mqtt://test.mosquitto.org
MQTT_TOPIC=orin/room/control

# Persistence
REDIS_URL=redis://127.0.0.1:6379
STATE_PROVIDER=redis

# API
API_HOST=127.0.0.1
API_PORT=3001
ALLOWED_ORIGIN=http://localhost:3000
API_KEY=orin_secret_key_2026_dev
